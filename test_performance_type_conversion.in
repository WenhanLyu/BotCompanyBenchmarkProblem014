# Performance and Memory Test for Type Conversion Functions
# This test verifies that type conversions do not introduce performance regressions or memory leaks

# Test 1: Large-scale int() conversions
print("Test 1: Converting 10000 floats to int")
count = 0
i = 0
while i < 10000:
    result = int(3.14159)
    count = count + 1
    i = i + 1
print(count)

# Test 2: Large-scale float() conversions
print("Test 2: Converting 10000 ints to float")
count = 0
i = 0
while i < 10000:
    result = float(42)
    count = count + 1
    i = i + 1
print(count)

# Test 3: Large-scale str() conversions
print("Test 3: Converting 10000 numbers to str")
count = 0
i = 0
while i < 10000:
    result = str(12345)
    count = count + 1
    i = i + 1
print(count)

# Test 4: Large-scale bool() conversions
print("Test 4: Converting 10000 values to bool")
count = 0
i = 0
while i < 10000:
    result = bool(1)
    count = count + 1
    i = i + 1
print(count)

# Test 5: Mixed type conversions
print("Test 5: Mixed type conversions - 5000 iterations")
count = 0
i = 0
while i < 5000:
    a = int(3.14)
    b = float(42)
    c = str(123)
    d = bool(1)
    count = count + 1
    i = i + 1
print(count)

# Test 6: Nested conversions
print("Test 6: Nested conversions - 1000 iterations")
count = 0
i = 0
while i < 1000:
    a = int(float(str(42)))
    b = str(int(float(99)))
    c = bool(int(1))
    count = count + 1
    i = i + 1
print(count)

# Test 7: String to number conversions (more expensive)
print("Test 7: String to number conversions - 5000 iterations")
count = 0
i = 0
while i < 5000:
    a = int("12345")
    b = float("3.14159")
    count = count + 1
    i = i + 1
print(count)

# Test 8: Large BigInteger conversions to string
print("Test 8: Large BigInteger to string conversions - 1000 iterations")
count = 0
i = 0
# Create a large number through multiplication
big = 123456789
big = big * big
big = big * big
while i < 1000:
    s = str(big)
    count = count + 1
    i = i + 1
print(count)

# Test 9: Memory stress test - repeated allocations
print("Test 9: Memory stress test - 10000 str allocations")
count = 0
i = 0
while i < 10000:
    # Each iteration creates new strings that should be freed
    s1 = str(12345)
    s2 = str(67890)
    s3 = str(11111)
    count = count + 1
    i = i + 1
print(count)

# Test 10: Conversion chain stress test
print("Test 10: Conversion chain - 2000 iterations")
count = 0
i = 0
while i < 2000:
    # int -> str -> int -> float -> str -> float
    a = 42
    b = str(a)
    c = int(b)
    d = float(c)
    e = str(d)
    f = float(e)
    count = count + 1
    i = i + 1
print(count)

print("All performance tests completed successfully")
