# Comprehensive Subscript Operations Test Suite
# M20: Test all subscript operations for lists, tuples, and strings

print("=== SECTION 1: LIST INDEXING TESTS ===")

# 1.1 Positive indices
print("Test 1.1: List positive indexing")
a = [1, 2, 3]
print(a[0])
print(a[1])
print(a[2])

# 1.2 Negative indices
print("Test 1.2: List negative indexing")
b = [10, 20, 30, 40]
print(b[-1])
print(b[-2])
print(b[-3])
print(b[-4])

# 1.3 Single element list
print("Test 1.3: Single element list")
c = [42]
print(c[0])
print(c[-1])

# 1.4 Empty list (cannot be indexed)
print("Test 1.4: Empty list creation")
e = []
print(e)

# 1.5 Multi-element list
print("Test 1.5: Multi-element list")
f = [5, 10, 15, 20, 25, 30, 35, 40, 45, 50]
print(f[0])
print(f[5])
print(f[9])
print(f[-1])
print(f[-5])
print(f[-10])

print("=== SECTION 2: TUPLE INDEXING TESTS ===")

# 2.1 Positive indices - tuples from function returns
print("Test 2.1: Tuple positive indexing")
def make_tuple1():
    return 10, 20, 30

t1 = make_tuple1()
print(t1[0])
print(t1[1])
print(t1[2])

# 2.2 Negative indices
print("Test 2.2: Tuple negative indexing")
def make_tuple2():
    return 100, 200, 300, 400

t2 = make_tuple2()
print(t2[-1])
print(t2[-2])
print(t2[-3])
print(t2[-4])

# 2.3 Single value return (not a tuple)
print("Test 2.3: Single value (not tuple)")
def make_single():
    return 99

t3 = make_single()
print(t3)

# 2.4 Mixed type tuple
print("Test 2.4: Mixed type tuple")
def make_mixed():
    return 1, "hello", 3

t4 = make_mixed()
print(t4[0])
print(t4[1])
print(t4[2])

# 2.5 Two-element tuple
print("Test 2.5: Two-element tuple")
def make_pair():
    return "first", "second"

t5 = make_pair()
print(t5[0])
print(t5[1])
print(t5[-1])
print(t5[-2])

print("=== SECTION 3: STRING INDEXING TESTS ===")

# 3.1 Positive indices
print("Test 3.1: String positive indexing")
s1 = "hello"
print(s1[0])
print(s1[1])
print(s1[2])
print(s1[3])
print(s1[4])

# 3.2 Negative indices
print("Test 3.2: String negative indexing")
s2 = "world"
print(s2[-1])
print(s2[-2])
print(s2[-3])
print(s2[-4])
print(s2[-5])

# 3.3 Single character string
print("Test 3.3: Single character string")
s3 = "x"
print(s3[0])
print(s3[-1])

# 3.4 Empty string
print("Test 3.4: Empty string")
s4 = ""
print(s4)

# 3.5 Multi-word string
print("Test 3.5: Multi-word string")
s5 = "hello world"
print(s5[0])
print(s5[6])
print(s5[-1])
print(s5[5])

# 3.6 String with special characters
print("Test 3.6: String with numbers")
s6 = "abc123"
print(s6[0])
print(s6[3])
print(s6[-1])

print("=== SECTION 4: EDGE CASES ===")

# 4.1 Index = 0 (first element)
print("Test 4.1: Index = 0")
print([5, 6, 7][0])
print("abc"[0])

# 4.2 Index = len-1 (last element positive)
print("Test 4.2: Last element (positive index)")
print([5, 6, 7][2])
print("abc"[2])

# 4.3 Index = -1 (last element negative)
print("Test 4.3: Last element (negative index)")
print([5, 6, 7][-1])
print("abc"[-1])

# 4.4 BigInteger indices (large numbers that become valid indices)
print("Test 4.4: BigInteger as index")
big_idx = 12345678901234567890 % 3
test_list = [111, 222, 333]
print(big_idx)
print(test_list[big_idx])

# 4.5 Zero in different contexts
print("Test 4.5: Zero index")
zero = 0
print([99, 88, 77][zero])
print("test"[zero])

# 4.6 Computed indices
print("Test 4.6: Computed indices")
x = 5
y = 3
idx = x - y
print([10, 20, 30, 40][idx])

print("=== SECTION 5: INTEGRATION TESTS ===")

# 5.1 Variables as indices
print("Test 5.1: Variable as index")
arr = [100, 200, 300, 400]
idx = 2
print(arr[idx])
idx = -1
print(arr[idx])
idx = 0
print(arr[idx])

# 5.2 Expressions as indices
print("Test 5.2: Expression as index")
print([10, 20, 30, 40][1 + 1])
print([10, 20, 30, 40][3 - 1])
print("test"[2 * 1])
print("test"[4 - 2])

# 5.3 Nested subscripts
print("Test 5.3: Nested subscripts")
def make_nested():
    return [1, 2], [3, 4]

nested = make_nested()
print(nested[0][0])
print(nested[0][1])
print(nested[1][0])
print(nested[1][1])
print(nested[-1][-1])
print(nested[-2][-2])

# 5.4 Subscripts in functions
print("Test 5.4: Subscripts in functions")
def get_element(lst, i):
    return lst[i]

print(get_element([5, 10, 15], 1))
print(get_element("python", 0))
print(get_element([7, 8, 9], -1))

# 5.5 Subscripts in loops
print("Test 5.5: Subscripts in loops")
data = [2, 4, 6, 8, 10]
i = 0
while i < 5:
    print(data[i])
    i = i + 1

# 5.6 Subscripts with range
print("Test 5.6: Subscripts with range")
letters = "abcde"
i = 0
while i < 5:
    print(letters[i])
    i = i + 1

# 5.7 Mixed operations
print("Test 5.7: Mixed subscript operations")
def process():
    return "result", 42, [1, 2, 3]

result = process()
print(result[0])
print(result[1])
print(result[2][0])
print(result[2][1])
print(result[2][2])

# 5.8 Subscript on function return via variable
print("Test 5.8: Subscript on return value")
def get_list():
    return [77, 88, 99]

temp = get_list()
print(temp[0])
print(temp[1])
print(temp[-1])

# 5.9 Subscript with string operations
print("Test 5.9: Subscript on string expressions")
s = "hello"
t = "world"
combined = s + t
print(combined[0])
print(combined[5])
print(combined[-1])

print("=== ALL TESTS COMPLETE ===")
