# Test 3: Return from deeply nested structures
def deep_search(target):
    i = 0
    while i < 3:
        j = 0
        while j < 3:
            k = 0
            while k < 3:
                if i == 1:
                    if j == 1:
                        if k == target:
                            return i * 100 + j * 10 + k
                k = k + 1
            j = j + 1
        i = i + 1
    return -1

print(deep_search(0))
print(deep_search(1))
print(deep_search(2))
print(deep_search(3))
