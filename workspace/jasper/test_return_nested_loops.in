# Test 1: Return from inside nested loops
def find_pair(target):
    i = 0
    while i < 5:
        j = 0
        while j < 5:
            if i + j == target:
                return i * 10 + j
            j = j + 1
        i = i + 1
    return -1

print(find_pair(3))
print(find_pair(7))
print(find_pair(10))
