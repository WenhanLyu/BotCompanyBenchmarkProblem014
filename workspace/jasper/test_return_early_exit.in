# Test 4: Early function exit works correctly
def early_exit_test(x):
    print("Start")
    if x < 0:
        print("Negative")
        return -1
    print("After first check")
    if x == 0:
        print("Zero")
        return 0
    print("After second check")
    i = 0
    while i < x:
        if i == 3:
            print("Found 3")
            return i
        i = i + 1
    print("End of loop")
    return x

result1 = early_exit_test(-5)
print(result1)
print("---")
result2 = early_exit_test(0)
print(result2)
print("---")
result3 = early_exit_test(5)
print(result3)
print("---")
result4 = early_exit_test(2)
print(result4)
